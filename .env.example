# Pi-hole Docker Environment Configuration
# Copy this file to .env and customize as needed

# Admin web interface password (CHANGE THIS!)
WEBPASSWORD=admin123

# Timezone
TZ=UTC

# Enable query logging
QUERY_LOGGING=true

# DNS listening mode
DNSMASQ_LISTENING=all

# UID/GID for Pi-hole process
PIHOLE_UID=999
PIHOLE_GID=999

# Temperature unit (C or F)
TEMPERATURE_UNIT=C

# Admin email
ADMIN_EMAIL=admin@pihole.local

# Enable DNSSEC verification
FTLCONF_VERIFY_DNSSEC=true
