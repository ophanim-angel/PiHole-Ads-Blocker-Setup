# Pi-hole Docker Environment Configuration
# Copy this file to .env and customize as needed using this command on bash "cp .env.example .env" 

# Admin web interface password (CHANGE THIS!)
WEBPASSWORD=admin123

# Timezone — find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: Europe/London, America/New_York, Asia/Tokyo
TZ=Europe/London

# Enable DNS query logging (true/false)
QUERY_LOGGING=true

# DNS listening mode — 'all' listens on all interfaces (needed for network-wide blocking)
DNSMASQ_LISTENING=all

# UID/GID for Pi-hole process (use 'id' command to find your UID/GID)
PIHOLE_UID=1000
PIHOLE_GID=1000

# Temperature unit (C or F)
TEMPERATURE_UNIT=C

# Admin email (optional)
ADMIN_EMAIL=admin@pihole.local

# Your machine's local IPv4 address (run: hostname -I | awk '{print $1}')
# This helps Pi-hole show the correct IP in the web UI
FTLCONF_LOCAL_IPV4=